[run]
# Coverage configuration for PlexiChat
branch = True
source = src
omit = 
    */tests/*
    */test_*.py
    */__pycache__/*
    */site-packages/*
    */venv/*
    */.venv/*
    */conftest.py
    */pytest_plugins.py

parallel = True
concurrency = multiprocessing

[report]
# Target coverage: 85% for plexichat
precision = 2
show_missing = True
skip_covered = False
skip_empty = True

# Fail if coverage is below threshold
fail_under = 85

exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstract
    @abstractmethod
    pass
    \.\.\.

[html]
directory = htmlcov
title = PlexiChat Test Coverage Report

[xml]
output = coverage.xml

[json]
output = coverage.json
pretty_print = True
