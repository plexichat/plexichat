# Plexichat Docker Environment Configuration
# Copy this file to .env and fill in the values
# Generated by docker/bootstrap/bootstrap.py on first run

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=plexichat
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DBNAME=plexichat
POSTGRES_SSLMODE=disable

# ============================================================================
# DATABASE CONNECTION POOL
# Controls how many connections are kept open to PostgreSQL
# Development defaults: min=5, max=20
# Production tuning: min=20, max=100-200 (depends on concurrent users)
# See docs/deployment/docker/connection-pooling.md for details
# ============================================================================
DB_POOL_MIN_CONNECTIONS=5
DB_POOL_MAX_CONNECTIONS=20
DB_POOL_CONNECT_TIMEOUT=10
DB_POOL_MAX_IDLE_TIME=300
DB_POOL_VALIDATION_INTERVAL=60
DB_POOL_ENABLE_VALIDATION=true
DB_POOL_VALIDATION_QUERY=SELECT 1

# ============================================================================
# REDIS CONFIGURATION
# In-memory cache for sessions, rate limiting, WebSocket state
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_ENABLED=true

# ============================================================================
# REDIS CONNECTION POOL
# ============================================================================
REDIS_CONNECTION_POOL=50

# ============================================================================
# MINIO / S3 CONFIGURATION
# Object storage for media files (avatars, attachments, etc.)
# ============================================================================
MINIO_ROOT_USER=plexichat
MINIO_ROOT_PASSWORD=your-minio-password-here
S3_BUCKET=plexichat-media
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=plexichat
S3_SECRET_KEY=your-s3-secret-key-here
S3_PUBLIC_URL=

# ============================================================================
# ENCRYPTION KEYS
# Critical security keys - keep these safe and never commit them
# Auto-generated by bootstrap if not provided
# ============================================================================
PLEXICHAT_SYSTEM_KEY=auto-generated-keep-secure
PLEXICHAT_MESSAGE_KEY=auto-generated-keep-secure
PLEXICHAT_MEDIA_KEY=auto-generated-keep-secure

# ============================================================================
# SMTP EMAIL CONFIGURATION
# For email verification, password reset, notifications
# Only required if email features are enabled
# ============================================================================
PLEXICHAT_SMTP_HOST=smtp.example.com
PLEXICHAT_SMTP_PORT=587
PLEXICHAT_SMTP_USER=noreply@example.com
PLEXICHAT_SMTP_PASSWORD=your-smtp-password-here
PLEXICHAT_SMTP_USE_TLS=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# MONITORING CONFIGURATION
# ============================================================================
MONITORING_ENABLED=true
MONITORING_METRICS_ENABLED=true
MONITORING_LOG_INTERVAL=300

# Alert thresholds - triggered when exceeded
MONITORING_ALERT_CPU_THRESHOLD=80
MONITORING_ALERT_MEMORY_THRESHOLD=85
MONITORING_ALERT_DB_POOL_THRESHOLD=75
MONITORING_ALERT_QUERY_TIME_MS=5000
MONITORING_ALERT_DB_ERRORS_PER_MINUTE=10
MONITORING_ALERT_API_RESPONSE_TIME_MS=2000
MONITORING_ALERT_ERROR_RATE_PERCENT=5
MONITORING_ALERT_ACTIVE_CONNECTIONS=1000

# ============================================================================
# CONFIGURATION OVERRIDES
# Set to "false" for strict config validation (recommended for production)
# ============================================================================
NO_STRICT_CONFIG=false
