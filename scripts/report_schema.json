{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Type Check Report Schema",
  "description": "Schema for programmatic consumption of type checking reports",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of report generation"
        },
        "pyright_version": {
          "type": "string",
          "description": "Version of pyright used"
        },
        "config_file": {
          "type": "string",
          "description": "Path to pyrightconfig.json used"
        }
      },
      "required": ["generated_at"]
    },
    "repositories": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Repository name (plexichat, common-utils, encryption)"
          },
          "path": {
            "type": "string",
            "description": "Absolute path to repository"
          },
          "success": {
            "type": "boolean",
            "description": "Whether type checking completed successfully"
          },
          "summary": {
            "type": "object",
            "properties": {
              "total_errors": {
                "type": "integer",
                "minimum": 0
              },
              "total_warnings": {
                "type": "integer",
                "minimum": 0
              },
              "total_info": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": ["total_errors", "total_warnings", "total_info"]
          },
          "categories": {
            "type": "object",
            "description": "Issues grouped by category",
            "patternProperties": {
              "^.*$": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "file": {
                      "type": "string",
                      "description": "Relative path to file with issue"
                    },
                    "line": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Line number (1-indexed)"
                    },
                    "column": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Column number (1-indexed)"
                    },
                    "severity": {
                      "type": "string",
                      "enum": ["error", "warning", "information"],
                      "description": "Issue severity"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    },
                    "rule": {
                      "type": "string",
                      "description": "Pyright rule code (e.g., reportOptionalMemberAccess)"
                    },
                    "category": {
                      "type": "string",
                      "enum": [
                        "Optional",
                        "List/Dict",
                        "Return Type",
                        "Import",
                        "Async",
                        "Type Annotation",
                        "Argument Type",
                        "Assignment",
                        "Other"
                      ],
                      "description": "Automatically assigned category"
                    }
                  },
                  "required": ["file", "line", "column", "severity", "message", "rule", "category"]
                }
              }
            }
          }
        },
        "required": ["name", "path", "success", "summary", "categories"]
      }
    },
    "aggregated_statistics": {
      "type": "object",
      "description": "Statistics across all repositories",
      "properties": {
        "total_errors": {
          "type": "integer",
          "minimum": 0
        },
        "total_warnings": {
          "type": "integer",
          "minimum": 0
        },
        "total_info": {
          "type": "integer",
          "minimum": 0
        },
        "by_category": {
          "type": "object",
          "patternProperties": {
            "^.*$": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "by_repository": {
          "type": "object",
          "patternProperties": {
            "^.*$": {
              "type": "object",
              "properties": {
                "errors": {
                  "type": "integer",
                  "minimum": 0
                },
                "warnings": {
                  "type": "integer",
                  "minimum": 0
                },
                "info": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        },
        "hotspot_files": {
          "type": "array",
          "description": "Files with the most issues",
          "items": {
            "type": "object",
            "properties": {
              "repository": {
                "type": "string"
              },
              "file": {
                "type": "string"
              },
              "total_issues": {
                "type": "integer",
                "minimum": 0
              },
              "by_category": {
                "type": "object",
                "patternProperties": {
                  "^.*$": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            },
            "required": ["repository", "file", "total_issues"]
          }
        }
      },
      "required": ["total_errors", "total_warnings", "total_info"]
    },
    "recommendations": {
      "type": "array",
      "description": "Prioritized fix recommendations",
      "items": {
        "type": "object",
        "properties": {
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "Priority level (1 = highest)"
          },
          "category": {
            "type": "string",
            "description": "Issue category to address"
          },
          "issue_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of issues in this category"
          },
          "description": {
            "type": "string",
            "description": "Why this is important"
          },
          "action_items": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Specific actions to take"
          }
        },
        "required": ["priority", "category", "issue_count", "description", "action_items"]
      }
    }
  },
  "required": ["metadata", "repositories", "aggregated_statistics"],
  "definitions": {
    "category_types": {
      "description": "Standard issue categories",
      "enum": [
        "Optional",
        "List/Dict",
        "Return Type",
        "Import",
        "Async",
        "Type Annotation",
        "Argument Type",
        "Assignment",
        "Other"
      ]
    }
  }
}
